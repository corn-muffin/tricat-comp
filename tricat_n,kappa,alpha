#area multiplicity for a dyck path
def v_dyck(b):
    area = b.to_area_sequence()

    m = max(area)

    v = [0]*(m+1)

    for a in area:
        v[a] += 1

    return v

#area multiplicity vector
def v(P):
  b = P.upper_dyck_word()
  return v_dyck(b)

#number of connected components in the decreasing forest 
def r(P):
    roots = P.decreasing_roots()
    return len(list(roots))


#dinv of the upper dyck path
def dinv(P):
  return t^(P.upper_dyck_word()).dinv()

#distance
def d(P):
  return q^(P.number_of_tamari_inversions())

#a is a composition, s<=n, f(a,s) is tricat_n,s,a
def f(a,s):
    poly = 0
    for P in TIP:
        if v(P) == a and r(P) == s:
            poly = poly + d(P)*d(P)
    return poly


