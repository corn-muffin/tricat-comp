#couldn't find this in sage for some reason, but dp to compute longest chain from v to all other vertices in graph reachable from v
#exploits fact that poset is a DAG
def longest_chain_lengths(G, v):
    top_order = G.topological_sort()
    distances = {v: 0}
    for v in top_order:
        if v not in distances:
            continue
        for w in G.neighbor_out_iterator(v):
            if w in distances:
                distances[w] = max(distances.get(w), distances[v] + 1)
            else:
                distances[w] = distances[v] + 1
    return distances



def i(b):
  H = G.reverse()
  distances = longest_chain_lengths(H,b)
  f = 0
  for key in distances:
      f = f+q^(distances[key])
  return f


#returns a polynomial in t
def dinv(b):
  return t^DyckWord(list(b)[0:-1]).dinv() 

def bounce(b):
    return DyckWord(list(b[0:-1])).bounce()

#returns a polynomial in q, t
def A():
  f = 0
  for b in P:
    f = f + i(b)*bounce(b)
  return f

